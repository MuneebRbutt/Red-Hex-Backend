# ── Runtime ──────────────────────────────────────────────────────────────────
APP_ENV=prod
PORT=3000

# ── Auth (use strong values in production) ───────────────────────────────────
COOKIE_SECRET=change-me-to-a-long-random-string
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me

# ── Database (Railway PostgreSQL — auto-injected as DATABASE_URL) ─────────────
DATABASE_URL=postgresql://user:pass@host:5432/railway
DATABASE_SSL=true
# Set to true ONLY on first Railway deploy to create tables, then remove
DB_SYNCHRONIZE=true

# ── URLs ─────────────────────────────────────────────────────────────────────
# Your Railway service public URL (no trailing slash)
PUBLIC_URL=https://your-app.up.railway.app
# Your Vercel storefront URL (for CORS + email links)
STOREFRONT_URL=https://your-site.vercel.app
# Comma-separated extra origins if needed
# CORS_ORIGINS=https://your-site.vercel.app,https://www.yourdomain.com

# ── Assets ───────────────────────────────────────────────────────────────────
# Railway volume mount path (recommended for persistent uploads)
# ASSET_UPLOAD_DIR=/data/assets
# ASSET_URL_PREFIX=https://your-app.up.railway.app/assets/

# ── Email (optional) ─────────────────────────────────────────────────────────
# EMAIL_FROM="RED HEX INDUSTRIES" <info@redhex.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
